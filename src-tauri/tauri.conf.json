{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pella Order Automation",
  "version": "0.1.0",
  "identifier": "com.pellaorderautomation.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pella Order Automation",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 650,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/pella-generator"]
  }
}
