{
  "name": "pella-order-automation-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri",
    "desktop:dev": "node scripts/tauri-dev.mjs",
    "sidecar:build": "node scripts/build-generator.mjs",
    "desktop:build": "tauri build",
    "desktop:package": "npm run sidecar:build && npm run desktop:build",
    "desktop:package:mac": "npm run sidecar:build && npm run tauri -- build --bundles app,dmg",
    "desktop:package:windows": "npm run desktop:package:windows:portable",
    "desktop:package:windows:portable": "npm run sidecar:build && npm run tauri -- build --no-bundle && node scripts/package-windows-portable.mjs",
    "desktop:package:windows:installer": "npm run sidecar:build && npm run tauri -- build --bundles nsis"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@vitejs/plugin-react": "3.1.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "4.5.3"
  }
}
